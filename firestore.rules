rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public access
    match /public/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Users collection
    match /users/{userId} {
      // Allow users to read their own profile
      allow read: if request.auth.uid == userId;
      
      // Allow admins to read/write any user
      allow write: if request.auth.token.admin == true;
      
      // Allow anyone to create new user (signup)
      allow create: if request.auth.uid == userId && request.resource.data.keys().hasAll(['email', 'name', 'role', 'orgId', 'createdAt']);
    }

    // Org collection - only readable by members of that org
    match /orgs/{orgId} {
      // Only allow reads if user is member of org
      allow read: if 
        request.auth.uid != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
      
      // Only allow writes if user is admin of org
      allow write: if 
        request.auth.uid != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Allow creation by authenticated users (first time org setup)
      allow create: if request.auth.uid != null && request.resource.data.keys().hasAll(['orgId', 'encryptedDek', 'createdAt']);
    }

    // Org-scoped collections
    match /orgs/{orgId}/{collection}/{document=**} {
      // Only allow access if user is member of org
      allow read, write: if 
        request.auth.uid != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
    }

    // Audit logs - only readable by admins
    match /auditLogs/{document=**} {
      allow read: if request.auth.token.admin == true;
      allow write: if true; // Allow any authenticated user to write audit logs
    }

    // Public collections
    match /public/{collection}/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}