rules_version = '2';
// Auto-deployed via GitHub Actions on push to main — project: deeltrack
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userDocData() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function userOrgId() {
      return userDocData().orgId;
    }

    function ownsOrg(orgId) {
      return isSignedIn() && (
        userOrgId() == orgId ||
        // Multi-org: users may belong to multiple orgs via orgIds array
        (userDocData().orgIds is list && orgId in userDocData().orgIds)
      );
    }

    function isInvestorRole() {
      return isSignedIn() && userDocData().role == 'Investor';
    }

    // Check if user is an org admin (owner or admin member)
    function isOrgAdmin(orgId) {
      return ownsOrg(orgId) && !isInvestorRole() && (
        // Primary org owner
        userOrgId() == orgId ||
        // Or has admin/owner role in members subcollection
        (exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(uid()))
         && get(/databases/$(database)/documents/orgs/$(orgId)/members/$(uid())).data.role in ['owner', 'admin'])
      );
    }

    // ── Internal config (Stripe keys, email config) — Cloud Functions only ──
    match /_config/{docId} {
      allow read, write: if false;
    }

    // ── Stripe event logs — Cloud Functions only ─────────────────────────────
    match /_stripe_events/{docId} {
      allow read, write: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && uid() == userId;

      allow create: if isSignedIn() && uid() == userId
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.role in ['General Partner', 'Investor'];

      // UPDATE: role, orgId, orgIds immutable from client (Cloud Functions only)
      allow update: if isSignedIn() && uid() == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.orgId == resource.data.orgId
        && request.resource.data.orgIds == resource.data.orgIds;
    }

    // ── Org data ──────────────────────────────────────────────────────────────

    match /orgs/{orgId} {
      allow read, write: if ownsOrg(orgId);

      // ── Team Members ────────────────────────────────────────────────────────
      // Members can read the team list. Only admins/owners can write.
      // Adding/removing is done via Cloud Functions to maintain orgIds array.
      match /members/{memberId} {
        allow read: if ownsOrg(orgId);
        allow write: if isOrgAdmin(orgId);
      }

      // ── Team Invites ────────────────────────────────────────────────────────
      // Admins create invites. Anyone signed in can read (to accept).
      match /team_invites/{inviteId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isOrgAdmin(orgId);
      }

      match /deals/{dealId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole();
      }

      match /investors/{investorId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole()
          && resource.data.email == request.auth.token.email;
      }

      match /documents/{docId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole() && (
          resource.data.accessLevel == 'all_investors' ||
          resource.data.accessLevel == userDocData().investorId
        );
      }

      match /distributions/{distId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole();
      }

      match /capitalCalls/{callId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole();
      }

      match /activity/{actId} {
        allow read, write: if ownsOrg(orgId);
      }

      match /settings/{settingId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
      }

      match /custom_data/{docId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole()
          && (resource.data.investorEmail == request.auth.token.email
              || resource.data.accessLevel == 'all_investors');
      }

      match /esign_log/{docId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole();
      }

      match /deal_invites/{inviteId} {
        allow read: if isSignedIn();
        allow write: if ownsOrg(orgId) && !isInvestorRole();
      }

      match /commitments/{commitId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole();
        allow create: if isSignedIn();
      }

      match /signing_requests/{reqId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read, update: if isSignedIn();
      }

      // ── Error logs ──────────────────────────────────────────────────────────
      match /errors/{errorId} {
        allow create: if ownsOrg(orgId);
        allow read: if ownsOrg(orgId) && !isInvestorRole();
      }
    }

    // ── E-Sign Requests (top-level, cross-org) ────────────────────────────
    match /esign_requests/{reqId} {
      allow create: if isSignedIn() && !isInvestorRole();
      allow read, update: if isSignedIn() && !isInvestorRole()
        && resource.data.orgId == userOrgId();
      allow read, update: if isSignedIn() && isInvestorRole()
        && resource.data.investorEmail == request.auth.token.email;
    }

    // ── Audit logs — Cloud Functions only ───────────────────────────────────
    match /auditLogs/{document=**} {
      allow read: if false;
      allow write: if false;
    }

    // ── Global invite index ─────────────────────────────────────────────────
    match /_invites/{token} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && !isInvestorRole();
    }

    // ── Team invite index (email → orgId lookup for join flow) ──────────────
    match /_team_invites/{token} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions only
    }
  }
}
