rules_version = '2';
// Auto-deployed via GitHub Actions on push to main — project: deeltrack
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userDocData() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function userOrgId() {
      return userDocData().orgId;
    }

    function ownsOrg(orgId) {
      return isSignedIn() && (
        userOrgId() == orgId ||
        // Multi-org: LP investors may belong to multiple orgs via orgIds array
        (userDocData().orgIds is list && orgId in userDocData().orgIds)
      );
    }

    function isInvestorRole() {
      return isSignedIn() && userDocData().role == 'Investor';
    }

    // ── Internal config (Stripe keys, email config) — Cloud Functions only ──
    match /_config/{docId} {
      allow read, write: if false; // Only accessible via Admin SDK in Cloud Functions
    }

    // ── Stripe event logs — Cloud Functions only ─────────────────────────────
    match /_stripe_events/{docId} {
      allow read, write: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users can read their own profile.
    // Users can UPDATE their own profile, but CANNOT change role or orgId.
    // Only Cloud Functions (Admin SDK) can set role/orgId — prevents privilege escalation.

    match /users/{userId} {
      allow read: if isSignedIn() && uid() == userId;

      // CREATE: only allowed for initial profile setup (signup)
      // role + orgId are set during creation and locked after that
      allow create: if isSignedIn() && uid() == userId
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.role in ['General Partner', 'Investor'];

      // UPDATE: allowed but role and orgId are immutable from client
      allow update: if isSignedIn() && uid() == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.orgId == resource.data.orgId;
    }

    // ── Org data ──────────────────────────────────────────────────────────────

    match /orgs/{orgId} {
      allow read, write: if ownsOrg(orgId);

      match /deals/{dealId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        // Investors can read deals they're linked to
        allow read: if ownsOrg(orgId) && isInvestorRole();
      }

      match /investors/{investorId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        // Investors can ONLY read their own record (matched by email on the document)
        allow read: if ownsOrg(orgId) && isInvestorRole()
          && resource.data.email == request.auth.token.email;
      }

      match /documents/{docId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole() && (
          resource.data.accessLevel == 'all_investors' ||
          resource.data.accessLevel == userDocData().investorId
        );
      }

      match /distributions/{distId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole();
      }

      match /capitalCalls/{callId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        // Investors can read capital calls for deals they are linked to
        allow read: if ownsOrg(orgId) && isInvestorRole();
      }

      match /activity/{actId} {
        allow read, write: if ownsOrg(orgId);
      }

      match /settings/{settingId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
      }

      // Generic custom data store (k1_vault, dealroom_docs_*, investor_updates, etc.)
      // GP can read/write all; investors can only read docs tagged for them or marked public
      match /custom_data/{docId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole()
          && (resource.data.investorEmail == request.auth.token.email
              || resource.data.accessLevel == 'all_investors');
      }

      // E-signature log (Firma.dev signing requests)
      match /esign_log/{docId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole();
      }

      // Deal invite links — GP creates, any signed-in user can read (needed for invest.html)
      match /deal_invites/{inviteId} {
        allow read: if isSignedIn();
        allow write: if ownsOrg(orgId) && !isInvestorRole();
      }

      // Investment commitments — LP creates, GP reads/updates
      match /commitments/{commitId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read: if ownsOrg(orgId) && isInvestorRole();
        allow create: if isSignedIn(); // Any authenticated user can submit a commitment
      }

      // Signing requests — GP creates, LP reads and updates (to sign)
      match /signing_requests/{reqId} {
        allow read, write: if ownsOrg(orgId) && !isInvestorRole();
        allow read, update: if isSignedIn(); // LP needs to read and sign
      }
    }

    // ── E-Sign Requests (top-level, cross-org) ────────────────────────────
    match /esign_requests/{reqId} {
      allow create: if isSignedIn() && !isInvestorRole();
      allow read, update: if isSignedIn() && !isInvestorRole()
        && resource.data.orgId == userOrgId();
      allow read, update: if isSignedIn() && isInvestorRole()
        && resource.data.investorEmail == request.auth.token.email;
    }

    // ── Audit logs — Cloud Functions write, admins read ─────────────────────
    match /auditLogs/{document=**} {
      allow read: if false;   // Admin SDK only
      allow write: if false;  // Admin SDK only (Cloud Functions)
    }

    // ── Global invite index (token → orgId lookup for invest.html) ──────────
    match /_invites/{token} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && !isInvestorRole();
    }
  }
}
