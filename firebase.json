{
  "functions": {
    "source": "functions",
    "runtime": "nodejs18",
    "ignore": ["firebase.json", "**/firestore.indexes.json", "**/firestore.rules"],
    "predeploy": [
      "npm --prefix $RESOURCE_DIR install",
      "npm --prefix $RESOURCE_DIR run build"
    ]
  },
  "hosting": [
    {
      "target": "deeltrack",
      "public": "public",
      "ignore": ["firebase.json", "**/firestore.indexes.json", "**/firestore.rules", "functions/**"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}